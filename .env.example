DATABASE_URL=postgresql+asyncpg://user:pass@127.0.0.1:5432/tender_monitor?ssl=disable
ENVIRONMENT=development
LOG_LEVEL=INFO
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
EMAIL_TO=
# Public base URL used to build links inside outbound notification emails.
APP_BASE_URL=http://localhost:8000
# Local-units-per-1-USD, used to show local value plus converted USD in UI/email.
USD_FX_RATES={"USD":1,"KZT":470.17,"UZS":11970.68}
ANTHROPIC_API_KEY=
# Optional: enables title translation before matching/upsert.
GOOGLE_TRANSLATE_PA_API_KEY=
TRANSLATION_ENABLED=true
TRANSLATION_BATCH_SIZE=50
